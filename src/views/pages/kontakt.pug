extends ../layouts/main.pug

block content
  - const pageTitle = contact.title || 'Kontakt'
  section(id=slugify(pageTitle))
    .container
      h2.section-title.text-shine.text-center.text-uppercase= pageTitle
      .row.g-4
        .col-12.col-md-5
          .mb-4
            h3.contact-label.text-shine.text-uppercase.mb-1= contact.order_hint
            p.mb-0= contact.label_order_phone || 'Bestellungen nur per Telefon'
            p.mb-0
              a.contact-link(href='tel:' + contact.phone.replace(/\s/g, ''))= contact.phone
          .mb-4
            h3.contact-label.text-shine.text-uppercase.mb-1= contact.label_hours || 'Öffnungszeiten'
            each entry in (contact.hours || [])
              p.mb-0
                strong= entry.label
                br
                span= entry.times
          .mb-4
            h3.contact-label.text-shine.text-uppercase.mb-1= contact.label_directions || 'Anfahrt'
            p.mb-0= contact.address
            button.btn.btn-primary.mt-2(
                type='button',
                data-directions-trigger='true'
              )= contact.label_directions_button || 'Anfahrt berechnen'
        .col-12.col-md-7.px-0
          dfw-contact-map
            .map-loader(aria-hidden="true")
              img.map-loader__gear(src=basePath + '/assets/gear_01.svg', alt="")
            .map-scroll-wrapper.scrollbar-invisible(rv-scrollbar-draggable rv-element="scrollWrapperEl")
              img(src=basePath + '/assets/map.avif', alt="Karte Standort Das Frittierwerk", draggable="false", rv-on-load="center")
            a.map-copyright(href="https://www.openstreetmap.org/copyright", target="_blank", rel="nofollow")
              small.me-2 © OpenStreetMap-Mitwirkende
