{
  "name": "das-frittierwerk",
  "version": "1.0.0",
  "type": "module",
  "description": "Website for Das Frittierwerk restaurant",
  "main": "./src/ts/main.ts",
  "module": "src/ts/main.ts",
  "source": "src/ts/main.ts",
  "private": true,
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "watch": "node scripts/watch.js",
    "start": "concurrently 'yarn:watch' 'yarn:preview'",
    "hmr": "vite serve",
    "preview": "vite preview",
    "clear": "rm -rf ./_site",
    "check": "tsc --noEmit"
  },
  "files": [
    "src"
  ],
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "repository": "git@github.com:ArtCodeStudio/das-frittierwerk.git",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@ribajs/tsconfig": "2.0.0",
    "@types/js-yaml": "^4.0.9",
    "concurrently": "^9.2.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "pug": "^3.0.4",
    "sass": "^1.99.0",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "dependencies": {
    "@fontsource/palanquin": "^5.2.8",
    "@fontsource/palanquin-dark": "^5.2.8",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@popperjs/core": "^2.11.8",
    "@ribajs/bs5": "2.0.0",
    "@ribajs/core": "2.0.0",
    "@ribajs/extras": "2.0.0",
    "@ribajs/router": "2.0.0",
    "@ribajs/types": "2.0.0",
    "@ribajs/utils": "2.0.0",
    "bootstrap": "^5.3.8"
  },
  "packageManager": "yarn@4.14.1"
}
